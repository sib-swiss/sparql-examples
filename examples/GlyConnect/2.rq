#+ endpoint: https://glyconnect.expasy.org/sparql
#+ summary: Get all Glyconnect glycan with their graphical SNFG representation
PREFIX foaf: <http://xmlns.com/foaf/0.1/>
PREFIX glycan: <http://purl.jp/bio/12/glyco/glycan#>

SELECT distinct ?structure ?image 
where {
?structure glycan:glycosylates_at ?specificglycosite .
?structure foaf:depiction ?image  
  }
