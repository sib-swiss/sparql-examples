#+ endpoint: https://sparql.nextprot.org/sparql
#+ summary: Proteins that bind RNA but do not contain a RRM domain
#+ tags:
#+ - domain
#+ - nucleotide binding
#+ - region
#+ - tutorial
PREFIX : <http://nextprot.org/rdf/>
PREFIX nextprot_cv: <http://nextprot.org/rdf/terminology/>

SELECT DISTINCT ?entry WHERE {
 ?entry :isoform ?iso .
 ?iso :uniprotKeyword /:term nextprot_cv:KW-0694. #RNA-binding
 filter not exists {?iso :region/:term nextprot_cv:DO-00581} #RRM
}
