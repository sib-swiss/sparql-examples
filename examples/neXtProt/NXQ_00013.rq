#+ endpoint: https://sparql.nextprot.org/sparql
#+ summary: Proteins that have a protein kinase domain but lack protein kinase activity
#+ tags:
#+ - domain
#+ - enzyme
#+ - function
#+ - region
#+ - tutorial
PREFIX : <http://nextprot.org/rdf/>
PREFIX nextprot_cv: <http://nextprot.org/rdf/terminology/>

SELECT DISTINCT ?entry WHERE {
 ?entry :isoform ?iso.
 ?iso :region /:term nextprot_cv:DO-00529.
 filter not exists { ?iso :enzymeClassification / :term /:childOf nextprot_cv:2_7_-_- }
}
