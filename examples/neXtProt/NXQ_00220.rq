#+ endpoint: https://sparql.nextprot.org/sparql
#+ summary: Proteins located on chromosome MT (mitochondrial) coded by a gene located on the plus strand
#+ tags:
#+ - chromosomal location
#+ - tutorial
PREFIX : <http://nextprot.org/rdf/>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

SELECT DISTINCT ?entry WHERE {
 ?entry :gene ?gene .
 ?gene :chromosome "MT"^^xsd:string; :strand "1"^^xsd:string .
 }
