#+ endpoint: https://sparql.nextprot.org/sparql
#+ summary: Check there are no entries with peptide mapping annotations with evidence from MassIVE that is negative
#+ tags:
#+ - QC
#+ - evidence
#+ - negative
#+ - peptide
#+ - proteomics
PREFIX : <http://nextprot.org/rdf/>
PREFIX cv: <http://nextprot.org/rdf/terminology/>

select distinct ?entry where {
  ?entry :isoform /:peptideMapping /:evidence ?ev.
  ?ev :assignedBy ?src.
  filter (regex (?src,'MassIVE'))
  ?ev :negative 1.
}
