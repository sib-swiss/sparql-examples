#+ endpoint: https://sparql.nextprot.org/sparql
#+ summary: Proteins that are annotated with GO "F" (function) terms prefixed by "Not"
#+ tags:
#+ - function
#+ - tutorial
PREFIX : <http://nextprot.org/rdf/>

SELECT DISTINCT ?entry WHERE {
 ?entry :isoform ?iso.
 ?iso :goMolecularFunction ?statement.
 ?statement :negativeEvidence ?ev.
}
