#+ endpoint: https://sparql.nextprot.org/sparql
#+ summary: Check there are no entries with disease annotations with evidence from Orphanet of quality SILVER
#+ tags:
#+ - QC
#+ - disease
#+ - evidence
#+ - quality
PREFIX : <http://nextprot.org/rdf/>
PREFIX cv: <http://nextprot.org/rdf/terminology/>
PREFIX source: <http://nextprot.org/rdf/source/>

select distinct ?entry where {
  ?entry :isoform / :disease /:evidence ?ev1.
  ?ev1 :assignedBy source:Orphanet.
  ?ev1 :quality :SILVER.
}
