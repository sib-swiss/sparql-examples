#+ endpoint: https://sparql.nextprot.org/sparql
#+ summary: Proteins with cross-references to InterPro
#+ tags:
#+ - cross-reference
#+ - domain
#+ - tutorial
PREFIX : <http://nextprot.org/rdf/>
PREFIX db: <http://nextprot.org/rdf/db/>

SELECT DISTINCT ?entry ?iprac WHERE {
 ?entry :reference ?ref.
 ?ref :provenance db:InterPro.
 ?ref :accession ?iprac}
order by ?entry ?iprac
