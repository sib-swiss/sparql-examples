#+ endpoint: https://sparql.nextprot.org/sparql
#+ summary: Proteins with a mutagenesis in a position that correspond to an annotated active site
#+ tags:
#+ - active site
#+ - enzyme
#+ - mutagenesis
#+ - tutorial
PREFIX : <http://nextprot.org/rdf/>

SELECT DISTINCT ?entry WHERE {
 ?entry :isoform ?iso.
 ?iso :mutagenesis /:start ?mutaPos.
 ?iso :activeSite /:start ?actsitePos.
 filter (?mutaPos=?actsitePos)
}
