#+ endpoint: https://sparql.nextprot.org/sparql
#+ summary: Check there are no entries with antibody mapping annotations and no xrefs from HPA
#+ tags:
#+ - QC
#+ - antibody
PREFIX : <http://nextprot.org/rdf/>
PREFIX cv: <http://nextprot.org/rdf/terminology/>
PREFIX db: <http://nextprot.org/rdf/db/>

select distinct ?entry where {
  ?entry :isoform /:antibodyMapping ?map.
  filter not exists {?entry :reference /:provenance db:HPA. }
}
