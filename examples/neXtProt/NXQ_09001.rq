#+ endpoint: https://sparql.nextprot.org/sparql
#+ summary: Check there are no protein families with no entry associated
#+ tags:
#+ - QC
#+ - family
#+ - snorql-only
#+ - vocabulary
PREFIX : <http://nextprot.org/rdf/>
PREFIX cv: <http://nextprot.org/rdf/terminology/>

select distinct ?famac where {
  ?fam a :FamilyInfo .
  ?fam :accession ?famac .
  filter not exists {?member :family / :accession ?famac .}
}
order by ?famac
