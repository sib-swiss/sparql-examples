#+ endpoint: https://sparql.nextprot.org/sparql
#+ summary: Check there are no entries with an xref to PDBsum and no PDB mapping annotation
#+ tags:
#+ - 3D structure
#+ - QC
PREFIX : <http://nextprot.org/rdf/>
PREFIX cv: <http://nextprot.org/rdf/terminology/>
PREFIX db: <http://nextprot.org/rdf/db/>

select distinct ?entry where {
  ?entry :reference /:provenance db:PDBsum.
  filter not exists {?entry :isoform /:pdbMapping ?map.}
}
