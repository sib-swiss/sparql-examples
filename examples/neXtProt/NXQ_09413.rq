#+ endpoint: https://sparql.nextprot.org/sparql
#+ summary: Check there are no entries whose gene is located on chromosome unknown which does not have AC NX_O00370 NX_Q96PT3 NX_Q96PT4 NX_Q9UN81
#+ tags:
#+ - QC
#+ - chromosomal location
PREFIX : <http://nextprot.org/rdf/>
PREFIX cv: <http://nextprot.org/rdf/terminology/>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX entry: <http://nextprot.org/rdf/entry/>

select distinct ?entry where {
  ?entry :gene  ?gene .
  ?gene :chromosome "unknown"^^xsd:string .
  filter (?entry not in (entry:NX_O00370,entry:NX_Q96PT3,entry:NX_Q96PT4,entry:NX_Q9UN81))
}
