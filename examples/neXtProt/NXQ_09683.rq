#+ endpoint: https://sparql.nextprot.org/sparql
#+ summary: Check there are no entries with a variant annotation with an allele number of 0
#+ tags:
#+ - QC
#+ - variant
PREFIX : <http://nextprot.org/rdf/>
PREFIX cv: <http://nextprot.org/rdf/terminology/>

select distinct ?entry where {
  ?entry :isoform ?iso.
  ?iso :variant /:evidence ?ev.
  ?ev :allele-number ?allele.
  filter (?allele = 0)
}
