#+ endpoint: https://sparql.nextprot.org/sparql
#+ summary: Proteins belonging to a family with at least two members in the human proteome
#+ tags:
#+ - family
#+ - tutorial
PREFIX : <http://nextprot.org/rdf/>

SELECT DISTINCT ?entry WHERE {
 ?entry :familyName / :term ?ac.
 ?member :familyName / :term ?ac.
} group by ?entry having (count(distinct ?member) >= 2 )
