#+ endpoint: https://sparql.nextprot.org/sparql
#+ summary: Check there are no entries with GO cellular component annotations with the evidence code is ND (ECO:0000035)
#+ tags:
#+ - QC
#+ - evidence
#+ - filtering
PREFIX : <http://nextprot.org/rdf/>
PREFIX cv: <http://nextprot.org/rdf/terminology/>

select distinct ?entry where {
  ?entry :isoform ?iso.
  ?iso :goCellularComponent /:evidence /:evidenceCode cv:ECO_0000035.
}
