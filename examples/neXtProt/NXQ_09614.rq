#+ endpoint: https://sparql.nextprot.org/sparql
#+ summary: Check there are no entries with antibody mapping annotations from HPA for which there is xref from HPA
#+ tags:
#+ - HPA
#+ - QC
PREFIX : <http://nextprot.org/rdf/>
PREFIX cv: <http://nextprot.org/rdf/terminology/>
PREFIX source: <http://nextprot.org/rdf/source/>
PREFIX db: <http://nextprot.org/rdf/db/>

select distinct ?entry where {
  ?entry :isoform ?iso.
  ?iso :antibodyMapping /:evidence ?ev.
  ?ev :assignedBy source:Human_protein_atlas.
  filter not exists {?ev :fromXref db:HPA.}
}
