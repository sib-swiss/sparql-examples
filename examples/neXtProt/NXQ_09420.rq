#+ endpoint: https://sparql.nextprot.org/sparql
#+ summary: Check there are no entries that have an end position which is less than 0
#+ tags:
#+ - QC
#+ - chromosomal location
PREFIX : <http://nextprot.org/rdf/>
PREFIX cv: <http://nextprot.org/rdf/terminology/>

select distinct ?entry where {
  ?entry :gene ?gene.
  ?gene :end ?end.
  filter (?end< 0 )
}
