#+ endpoint: https://sparql.nextprot.org/sparql
#+ summary: Check there are no topological domains with no entry associated
#+ tags:
#+ - QC
#+ - snorql-only
#+ - topology
#+ - vocabulary
PREFIX : <http://nextprot.org/rdf/>
PREFIX cv: <http://nextprot.org/rdf/terminology/>

select distinct ?topoac where {
  ?topo a :TopologicalDomain .
  ?topo :term ?topoac .
  filter not exists {?member :isoform /:topology / :term ?topoac .}
}
order by ?topoac
