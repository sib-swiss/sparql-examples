#+ endpoint: https://sparql.nextprot.org/sparql
#+ summary: Check there are no entries with a gene name which does not contain a capital letter or is not "unknown"
#+ tags:
#+ - QC
#+ - gene name
PREFIX : <http://nextprot.org/rdf/>
PREFIX cv: <http://nextprot.org/rdf/terminology/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

select distinct ?entry ?name where {
  ?entry :gene / :name / rdfs:label ?name .
   filter (!regex (?name,'[A-Z]'))
   filter (!regex (?name,'unknown'))
}
