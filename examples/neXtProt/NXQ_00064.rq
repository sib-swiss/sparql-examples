#+ endpoint: https://sparql.nextprot.org/sparql
#+ summary: Proteins which are enzymes and that have an incomplete EC number
#+ tags:
#+ - enzyme
#+ - function
#+ - tutorial
PREFIX : <http://nextprot.org/rdf/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

SELECT DISTINCT ?entry WHERE {
 ?entry :isoform/ :enzymeClassification ?ec.
 ?ec :term / rdfs:label ?eclabel.
 filter regex(?eclabel, '-'^^xsd:string)
}
