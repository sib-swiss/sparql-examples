#+ endpoint: https://sparql.nextprot.org/sparql
#+ summary: Check there are no entries with a peptide mapping annotation with evidence from MassIVE but no xref to MassIVE
#+ tags:
#+ - QC
#+ - cross-reference
#+ - mass spectrometry
#+ - peptide
#+ - proteomics
PREFIX : <http://nextprot.org/rdf/>
PREFIX cv: <http://nextprot.org/rdf/terminology/>
PREFIX db: <http://nextprot.org/rdf/db/>

select distinct ?entry where {
  ?entry a :Entry.
  ?entry :isoform /:peptideMapping /:evidence /:assignedBy ?src.
  filter (regex (?src,'MassIVE'))
  filter not exists {?entry :reference /:provenance db:MassIVE.}
}
