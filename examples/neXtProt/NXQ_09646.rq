#+ endpoint: https://sparql.nextprot.org/sparql
#+ summary: Check there are no entries with the keyword KW-0225 (Disease mutation) that do not have a variant responsible for a disease
#+ tags:
#+ - QC
#+ - disease
#+ - keyword
#+ - variant
PREFIX : <http://nextprot.org/rdf/>
PREFIX cv: <http://nextprot.org/rdf/terminology/>

select distinct ?entry where {
  ?entry :isoform /:keyword /:term cv:KW-0225.
  filter not exists {?entry :isoform /:variant /:disease ?dis.}
}
