#+ endpoint: https://sparql.nextprot.org/sparql
#+ summary: Proteins with a mature chain of from 300 to 400 residues
#+ tags:
#+ - processing
#+ - sequence
#+ - tutorial
PREFIX : <http://nextprot.org/rdf/>

SELECT DISTINCT ?entry WHERE {
 ?entry :isoform ?iso.
 ?iso :matureProtein [ :start ?mstart ; :end ?mend].
 filter (?mend-?mstart > 0). # chain fully defined
 bind(?mend - ?mstart as ?mlen)
 filter(?mlen >= 300 && ?mlen <= 400)
}
