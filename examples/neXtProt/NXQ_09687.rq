#+ endpoint: https://sparql.nextprot.org/sparql
#+ summary: Check there are no entries whose gene is on chromosome unknown with a variant annotation with evidence from gnomAD 
#+ tags:
#+ - QC
#+ - variant
PREFIX : <http://nextprot.org/rdf/>
PREFIX cv: <http://nextprot.org/rdf/terminology/>
PREFIX source: <http://nextprot.org/rdf/source/>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

select distinct ?entry where {
  ?entry :gene / :chromosome "unknown"^^xsd:string.
  ?entry :isoform ?iso.
  ?iso :variant /:evidence ?ev.
  ?ev :assignedBy source:gnomAD.
}
