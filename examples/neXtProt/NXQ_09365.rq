#+ endpoint: https://sparql.nextprot.org/sparql
#+ summary: Check there are no entries with pathway annotations with evidence from Reactome that is negative
#+ tags:
#+ - QC
#+ - evidence
#+ - function
#+ - negative
PREFIX : <http://nextprot.org/rdf/>
PREFIX cv: <http://nextprot.org/rdf/terminology/>
PREFIX source: <http://nextprot.org/rdf/source/>

select distinct ?entry where {
  ?entry :isoform /:pathway /:evidence ?ev.
  ?ev :assignedBy source:Reactome.
  ?ev :negative 1.
}
