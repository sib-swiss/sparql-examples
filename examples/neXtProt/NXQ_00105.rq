#+ endpoint: https://sparql.nextprot.org/sparql
#+ summary: Proteins with at least one cross-reference to SMR (Swiss Model Repository) but no cross-references to PDB
#+ tags:
#+ - 3D structure
#+ - cross-reference
#+ - tutorial
PREFIX : <http://nextprot.org/rdf/>
PREFIX db: <http://nextprot.org/rdf/db/>

SELECT DISTINCT ?entry WHERE {
 ?entry a :Entry.
 ?entry :reference / :provenance db:SMR.
 filter not exists { ?entry :reference / :provenance db:PDB }
}
