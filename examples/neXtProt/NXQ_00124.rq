#+ endpoint: https://sparql.nextprot.org/sparql
#+ summary: What are the 25 most frequent families with member count
#+ tags:
#+ - family
#+ - tutorial
PREFIX : <http://nextprot.org/rdf/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

select (str(?famlab) as ?familylabel) (count(distinct(?member)) as ?membercnt) where{
 ?member :familyName /:term /:childOf / rdfs:label ?famlab .
} group by ?famlab
order by desc(?membercnt)
limit 25
