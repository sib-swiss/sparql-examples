#+ endpoint: https://sparql.nextprot.org/sparql
#+ summary: Proteins that have at least one 3D structure solved by NMR
#+ tags:
#+ - 3D structure
#+ - method
#+ - tutorial
PREFIX : <http://nextprot.org/rdf/>

SELECT DISTINCT ?entry WHERE {
 ?entry :isoform ?iso.
 ?iso :pdbMapping ?map.
 ?map :method ?meth
 filter (contains(?meth,'NMR'))
}
