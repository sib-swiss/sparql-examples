#+ endpoint: https://sparql.nextprot.org/sparql
#+ summary: Check there are no entries whose gene does not have a beginning position which has an end position
#+ tags:
#+ - QC
#+ - chromosomal location
PREFIX : <http://nextprot.org/rdf/>
PREFIX cv: <http://nextprot.org/rdf/terminology/>

select distinct ?entry where {
  ?entry :gene ?gene.
  ?gene :begin ?begin.
  ?gene :end ?end.
  filter (?begin = 0)
  filter (?end > 0)
}
