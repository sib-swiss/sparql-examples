#+ endpoint: https://sparql.nextprot.org/sparql
#+ summary: Proteins with protein existence "At protein level" (PE=1) and at least one proteotypic peptide
#+ tags:
#+ - peptide
#+ - protein existence
#+ - proteomics
#+ - tutorial
PREFIX : <http://nextprot.org/rdf/>

SELECT DISTINCT ?entry WHERE {
 ?entry :isoform / :peptideMapping ?pm .
 ?entry :existence :Evidence_at_protein_level .
 ?pm :proteotypic true .
}
