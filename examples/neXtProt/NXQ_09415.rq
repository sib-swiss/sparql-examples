#+ endpoint: https://sparql.nextprot.org/sparql
#+ summary: Check there are no entries whose gene is located on chromosome "unknown" which have a band
#+ tags:
#+ - QC
#+ - chromosomal location
PREFIX : <http://nextprot.org/rdf/>
PREFIX cv: <http://nextprot.org/rdf/terminology/>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

select distinct ?entry where {
  ?entry :gene  ?gene .
  ?gene :chromosome "unknown"^^xsd:string .
  filter not exists {?gene :band ?_ }
}
