#+ endpoint: https://sparql.nextprot.org/sparql
#+ summary: Proteins with a mitochondrial transit peptide
#+ tags:
#+ - sequence
#+ - subcellular location
#+ - tutorial
PREFIX : <http://nextprot.org/rdf/>

SELECT DISTINCT ?entry WHERE {
 ?entry :isoform ?iso.
 ?iso :mitochondrialTransitPeptide ?mit.
}
