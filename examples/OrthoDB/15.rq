#+ endpoint: https://sparql.orthodb.org/sparql/
#+ summary: Find orthologous group/s at any level containing protein with Uniprot id P12345
PREFIX uniprotkb: <http://purl.uniprot.org/uniprot/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX : <http://purl.orthodb.org/>

SELECT *
WHERE {
    ?og a :OrthoGroup ;
        :ogBuiltAt ?level;
        :hasMember/rdfs:seeAlso uniprotkb:P12345 .
}
