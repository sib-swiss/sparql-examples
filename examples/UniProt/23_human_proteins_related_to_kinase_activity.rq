#+ endpoint: https://sparql.uniprot.org/sparql/
#+ summary: Number of reviewed entries (UniProtKB/Swiss-Prot) that are related to <a href="http://amigo.geneontology.org/amigo/term/GO:0016301">kinase activity</a>
#+ tags:
#+ - count
#+ - entry status
#+ - gene ontology
PREFIX GO: <http://purl.obolibrary.org/obo/GO_>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX taxon: <http://purl.uniprot.org/taxonomy/>
PREFIX up: <http://purl.uniprot.org/core/>

SELECT
    (COUNT(DISTINCT(?protein)) AS ?pc)
WHERE
{   
    ?protein rdf:type up:Protein ;
        up:reviewed true  ;
        up:organism taxon:9606 ;
        up:classifiedWith|(up:classifiedWith/rdfs:subClassOf) GO:0016301 .
}
