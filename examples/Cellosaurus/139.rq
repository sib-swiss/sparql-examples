#+ endpoint: https://sparql.cellosaurus.org/sparql
#+ summary: Some cell lines with the age of the individual at which the sample was collected to create the cell line
#+ tags:
#+ - age
#+ - individual
PREFIX cello: <https://purl.expasy.org/cellosaurus/rdf/ontology/>
select ?cl ?cl_name ?individual_age  where {
  ?cl cello:derivedFromIndividualAtAge ?individual_age .
  ?cl cello:recommendedName ?cl_name .
}
order by ?cl
limit 100
