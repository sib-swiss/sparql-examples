#+ endpoint: https://sparql.cellosaurus.org/sparql
#+ summary: Top 100 parent cell lines (from which other cell lines have been derived)
#+ tags:
#+ - ch
#+ - child
#+ - stats
PREFIX cello: <https://purl.expasy.org/cellosaurus/rdf/ontology/>
select ?cl ?cl_name (count(?child) as ?child_count) where {
  ?cl cello:recommendedName ?cl_name .
  ?cl cello:hasChildCellLine ?child .
}
group by ?cl ?cl_name
order by desc(count(?child))
limit 100
