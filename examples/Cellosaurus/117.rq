#+ endpoint: https://sparql.cellosaurus.org/sparql
#+ summary: Count of cell lines by sex of the individual from which the cell line originates
#+ tags:
#+ - sex
#+ - sx
PREFIX cello: <https://purl.expasy.org/cellosaurus/rdf/ontology/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
select ?sex (count(?cl) as ?cl_count) where {
  ?cl a / rdfs:subClassOf cello:CellLine.
  optional { ?cl cello:derivedFromIndividualWithSex ?sex. }
}
group by ?sex
order by ?sex
